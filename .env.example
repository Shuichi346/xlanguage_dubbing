# ============================================================
# ja-dubbing 環境変数設定
# ============================================================

# === パス設定 ===
VIDEO_FOLDER=./input_videos
TEMP_ROOT=./temp
OUTPUT_SUFFIX=_jaDub.mp4
KEEP_TEMP=true

# === 音声設定 ===
TTS_SAMPLE_RATE=48000
TTS_CHANNELS=2
ENGLISH_VOLUME=0.10
JAPANESE_VOLUME=1.00
OUTPUT_SIZE=720

# ============================================================
# ASR（音声認識）
# ============================================================

# ASR エンジン: whisper（高速・英語主体向け）または vibevoice（多言語・話者分離内蔵・低速）
ASR_ENGINE=whisper

# --- whisper.cpp 設定（ASR_ENGINE=whisper のとき使用）---
WHISPER_MODEL=large-v3-turbo
WHISPER_LANG=en
VAD_MODEL=silero-v6.2.0
# whisper.cpp のインストール先ディレクトリ（setup_whisper.sh がクローンする場所）
WHISPER_CPP_DIR=./whisper.cpp

# --- VibeVoice-ASR 設定（ASR_ENGINE=vibevoice のとき使用）---
VIBEVOICE_MODEL=mlx-community/VibeVoice-ASR-8bit
VIBEVOICE_MAX_TOKENS=32768
# カスタムホットワード（固有名詞の認識補助、カンマ区切り）
VIBEVOICE_CONTEXT=

# VibeVoice エンコーダチャンク設定（通常は変更不要）
# VIBEVOICE_CHUNK_REFERENCE_AVAILABLE_GB=14.0
# VIBEVOICE_CHUNK_REFERENCE_SECONDS=600
# VIBEVOICE_CHUNK_SAFETY_MARGIN=0.80
# VIBEVOICE_CHUNK_MIN_SECONDS=120
# VIBEVOICE_CHUNK_MAX_SECONDS=1800
# VIBEVOICE_PREFILL_STEP_SIZE=512
# VIBEVOICE_MEMORY_LIMIT_RATIO=0.90

# ============================================================
# 話者分離（pyannote.audio）
# ============================================================

HF_AUTH_TOKEN=hf_xxxxxxxxxxxx
PYANNOTE_MODEL=pyannote/speaker-diarization-community-1

# ============================================================
# セグメント加工
# ============================================================

# --- セグメント設定 ---
MIN_SEGMENT_SEC=0.35
MERGE_MAX_SEC=12.0
MERGE_MAX_CHARS=320
MERGE_GAP_SEC=0.85
MERGE_FORCE_IF_VERY_SHORT_SEC=0.70

# --- spaCy設定 ---
SPACY_MODEL=en_core_web_sm
SPACY_CHUNK_MAX_SEC=18.0
SPACY_CHUNK_MAX_CHARS=1100
SPACY_CHUNK_GAP_SEC=1.0
SPACY_UNIT_MAX_SENTENCES=2
SPACY_UNIT_MERGE_MAX_CHARS=300
SPACY_UNIT_MERGE_MAX_GAP_SEC=1.20
SPACY_MIN_WEIGHT=1

# ============================================================
# 翻訳（CAT-Translate）
# ============================================================

# GGUF モデルのリポジトリとファイル名（huggingface_hub で自動ダウンロード）
CAT_TRANSLATE_REPO=mradermacher/CAT-Translate-7b-GGUF
CAT_TRANSLATE_FILE=CAT-Translate-7b.Q8_0.gguf
# GPU オフロードレイヤー数（-1 で全レイヤーを GPU に載せる）
CAT_TRANSLATE_N_GPU_LAYERS=-1
# コンテキストウィンドウサイズ
CAT_TRANSLATE_N_CTX=4096
# 翻訳リトライ回数
CAT_TRANSLATE_RETRIES=3
CAT_TRANSLATE_RETRY_BACKOFF_SEC=1.5
# 繰り返し抑制ペナルティ（1.0 で無効、1.1〜1.3 推奨）
CAT_TRANSLATE_REPEAT_PENALTY=1.2

# --- 翻訳異常検出 ---
# 翻訳「出力」（日本語）の異常検出: 同一フレーズがN回以上繰り返されていたら異常とみなす
OUTPUT_REPEAT_THRESHOLD=3
# 翻訳「入力」（英語）の繰り返し検出: 同一フレーズがN回以上出現していたらスキップ
INPUT_REPEAT_THRESHOLD=4
# 翻訳「入力」のユニーク率がこの値未満なら繰り返しとみなしてスキップ（0.0〜1.0）
INPUT_UNIQUE_RATIO_THRESHOLD=0.3

# ============================================================
# TTS（音声合成）
# ============================================================

# TTS エンジン: miotts / kokoro / gptsovits / t5gemma
TTS_ENGINE=miotts

# --- MioTTS-Inference（TTS_ENGINE=miotts のとき使用）---
MIOTTS_API_URL=http://localhost:8001
MIOTTS_HTTP_TIMEOUT=600
# MioTTS-Inference側のリファレンス音声上限は20秒。20秒以下に設定。
MIOTTS_REFERENCE_MAX_SEC=20.0
MIOTTS_MAX_TEXT_LENGTH=500
# HTTPエラー等のネットワーク障害リトライ回数（品質リトライとは独立）
MIOTTS_TTS_RETRIES=1
# 品質バリデーション失敗（異常に遅い/速い音声）時の再生成リトライ回数
MIOTTS_QUALITY_RETRIES=2

# --- MioTTS LLMバックエンド（TTS_ENGINE=miotts のとき使用）---
MIOTTS_LLM_PORT=8000
MIOTTS_LLM_MODEL=hf.co/Aratako/MioTTS-GGUF:MioTTS-1.7B-Q8_0.gguf
MIOTTS_DEVICE=mps
MIOTTS_CODEC_MODEL=Aratako/MioCodec-25Hz-44.1kHz-v2
MIOTTS_INFERENCE_DIR=./MioTTS-Inference

# --- MioTTS LLMサンプリングパラメータ（音声品質チューニング）---
# temperature: 低いほど安定した音声を生成する（0.1〜0.8、推奨0.5）
MIOTTS_LLM_TEMPERATURE=0.5
# top_p: トークン選択の多様性（1.0でフルサンプリング）
MIOTTS_LLM_TOP_P=1.0
# max_tokens: 最大生成トークン数（長いテキストほど大きく設定）
MIOTTS_LLM_MAX_TOKENS=700
# repetition_penalty: トークンの繰り返しを抑制（1.0で無効、1.1〜1.3推奨）
MIOTTS_LLM_REPETITION_PENALTY=1.1
# presence_penalty: 既出トークンの再出現を抑制（0.0〜1.0）
MIOTTS_LLM_PRESENCE_PENALTY=0.0
# frequency_penalty: 高頻度トークンを抑制（0.0〜1.0、0.2〜0.4推奨）
MIOTTS_LLM_FREQUENCY_PENALTY=0.3

# --- MioTTS 品質バリデーション ---
# 日本語1文字あたりの想定発話秒数の下限（これ未満は"異常に短い"と判定）
MIOTTS_DURATION_PER_CHAR_MIN=0.05
# 日本語1文字あたりの想定発話秒数の上限（これ超過は"異常に長い"と判定）
MIOTTS_DURATION_PER_CHAR_MAX=0.5
# バリデーション対象の最小テキスト文字数（短すぎるテキストは比率が不安定なのでスキップ）
MIOTTS_VALIDATION_MIN_CHARS=4

# --- T5Gemma-TTS（TTS_ENGINE=t5gemma のとき使用）---
# HuggingFace モデルリポジトリ名
T5GEMMA_MODEL_DIR=Aratako/T5Gemma-TTS-2b-2b
# XCodec2 音声コーデックモデル名（日本語音声に最適化された Variant を使用）
T5GEMMA_XCODEC2_MODEL=NandemoGHS/Anime-XCodec2-44.1kHz-v2
# サンプリングパラメータ
T5GEMMA_TOP_K=30
T5GEMMA_TOP_P=0.9
T5GEMMA_TEMPERATURE=0.8
# ランダムシード（再現性のため）
T5GEMMA_SEED=1
# 繰り返し停止閾値（同一トークンがこの回数連続したら生成を停止）
T5GEMMA_STOP_REPETITION=3
# 再生時間制御: 元セグメントの長さに対する倍率（1.0 = 元と同じ長さ）
# 少し余裕を持たせたい場合は 1.05〜1.1 に設定
T5GEMMA_DURATION_SCALE=1.15
# 参照音声の最大秒数（秒）。長すぎるとメモリ消費が増える
T5GEMMA_REFERENCE_MAX_SEC=15.0
# 参照音声の最小秒数（秒）
T5GEMMA_REFERENCE_MIN_SEC=5.0
# 参照音声の目標秒数（秒）
T5GEMMA_REFERENCE_TARGET_SEC=8.0
# XCodec2 を CPU にオフロードしてメモリを節約する（true 推奨、約3.5GB 節約）
T5GEMMA_CPU_CODEC=true
# 品質バリデーション: 生成音声の長さが target_duration のこの倍率を超えたら再生成
T5GEMMA_DURATION_TOLERANCE=0.5
# 品質リトライ回数
T5GEMMA_QUALITY_RETRIES=2

# --- Kokoro TTS（TTS_ENGINE=kokoro のとき使用）---
# モデル名（HuggingFace リポジトリ名）
KOKORO_MODEL=kokoro
# 日本語ボイス（jf_alpha, jf_gongitsune など）
KOKORO_VOICE=jf_alpha
# 読み上げ速度（1.0 が標準、0.8〜1.2 程度を推奨）
KOKORO_SPEED=1.0

# --- GPT-SoVITS（TTS_ENGINE=gptsovits のとき使用）---
# V2ProPlus モデルによるゼロショットボイスクローン
# GPT-SoVITS は独立した conda 環境で動作し、API サーバー経由でアクセスする
GPTSOVITS_API_URL=http://127.0.0.1:9880
GPTSOVITS_HTTP_TIMEOUT=300.0
GPTSOVITS_TTS_RETRIES=2
# GPT-SoVITS のインストール先ディレクトリ（setup_gptsovits.sh がクローンする場所）
GPTSOVITS_DIR=./GPT-SoVITS
# GPT-SoVITS 用 conda 環境名
GPTSOVITS_CONDA_ENV=gptsovits
# 合成テキストの言語（日本語）
GPTSOVITS_TEXT_LANG=ja
# 参照音声の言語（元動画が英語なので en）
GPTSOVITS_PROMPT_LANG=en
# サンプリングパラメータ（通常は変更不要）
GPTSOVITS_TOP_K=15
GPTSOVITS_TOP_P=1.0
GPTSOVITS_TEMPERATURE=1.0
# テキスト分割方式（cut5 = 句読点に基づく5文字以上の分割）
GPTSOVITS_TEXT_SPLIT_METHOD=cut5
GPTSOVITS_BATCH_SIZE=1
# 読み上げ速度（1.0 が標準）
GPTSOVITS_SPEED_FACTOR=1.0
GPTSOVITS_MEDIA_TYPE=wav
GPTSOVITS_REPETITION_PENALTY=1.35
# ゼロショット参照音声の長さ設定（秒）
# 3〜10秒（推奨5秒）。声質のみ抽出されるため短くてよい
GPTSOVITS_REFERENCE_MIN_SEC=3.0
GPTSOVITS_REFERENCE_MAX_SEC=10.0
GPTSOVITS_REFERENCE_TARGET_SEC=5.0
