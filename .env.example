# ============================================================
# xlanguage-dubbing 環境変数設定
# ============================================================

# === Hugging Faceトークン ===
HF_AUTH_TOKEN=hf_xxxxxxxxxxxx

# === パス設定 ===
VIDEO_FOLDER=./input_videos
TEMP_ROOT=./temp
OUTPUT_SUFFIX=_xlDub.mp4
KEEP_TEMP=true

# === 言語設定 ===
# INPUT_LANG: 大元の動画の音声言語。auto で ASR エンジンが自動判定
#   例: auto, en, ja, fr, de, zh, ko, es, etc.
INPUT_LANG=auto
# OUTPUT_LANG: 最終的に出力される動画の音声言語（必須・明示指定）
#   例: ja, en, fr, de, zh, ko, es, etc.
OUTPUT_LANG=ja

# === 音声設定 ===
TTS_SAMPLE_RATE=48000
TTS_CHANNELS=2
ORIGINAL_VOLUME=0.10
DUBBED_VOLUME=1.00
OUTPUT_SIZE=720

# ============================================================
# ASR（音声認識）
# ============================================================

# ASR エンジン: vibevoice（多言語・コードスイッチング対応・デフォルト）または whisper（高速・1言語）
ASR_ENGINE=vibevoice

# --- whisper.cpp 設定（ASR_ENGINE=whisper のとき使用）---
WHISPER_MODEL=large-v3-turbo
# WHISPER_LANG は INPUT_LANG=auto のとき auto になる。明示指定も可能。
WHISPER_LANG=auto
VAD_MODEL=silero-v6.2.0
WHISPER_CPP_DIR=./whisper.cpp

# --- VibeVoice-ASR 設定（ASR_ENGINE=vibevoice のとき使用）---
VIBEVOICE_MODEL=mlx-community/VibeVoice-ASR-8bit
VIBEVOICE_MAX_TOKENS=32768
VIBEVOICE_CONTEXT=

# ============================================================
# 話者分離（pyannote.audio）
# ============================================================

PYANNOTE_MODEL=pyannote/speaker-diarization-community-1

# ============================================================
# セグメント加工
# ============================================================

MIN_SEGMENT_SEC=0.35
MERGE_MAX_SEC=12.0
MERGE_MAX_CHARS=320
MERGE_GAP_SEC=0.85
MERGE_FORCE_IF_VERY_SHORT_SEC=0.70

SPACY_MODEL=en_core_web_sm
SPACY_CHUNK_MAX_SEC=18.0
SPACY_CHUNK_MAX_CHARS=1100
SPACY_CHUNK_GAP_SEC=1.0
SPACY_UNIT_MAX_SENTENCES=2
SPACY_UNIT_MERGE_MAX_CHARS=300
SPACY_UNIT_MERGE_MAX_GAP_SEC=1.20
SPACY_MIN_WEIGHT=1

# ============================================================
# 翻訳
# ============================================================

# --- CAT-Translate（日英特化・高精度）---
# 日英・英日の言語ペアの場合に自動選択される
CAT_TRANSLATE_REPO=mradermacher/CAT-Translate-7b-GGUF
CAT_TRANSLATE_FILE=CAT-Translate-7b.Q6_K.gguf
CAT_TRANSLATE_N_GPU_LAYERS=-1
CAT_TRANSLATE_N_CTX=4096
CAT_TRANSLATE_RETRIES=3
CAT_TRANSLATE_RETRY_BACKOFF_SEC=1.5
CAT_TRANSLATE_REPEAT_PENALTY=1.2

# --- TranslateGemma（多言語翻訳・55言語対応）---
# 日英以外の言語ペアの場合に自動選択される
TRANSLATEGEMMA_REPO=mradermacher/translategemma-12b-it-GGUF
TRANSLATEGEMMA_FILE=translategemma-12b-it.Q6_K.gguf
TRANSLATEGEMMA_N_GPU_LAYERS=-1
TRANSLATEGEMMA_N_CTX=2048
TRANSLATEGEMMA_RETRIES=3
TRANSLATEGEMMA_RETRY_BACKOFF_SEC=1.5
TRANSLATEGEMMA_REPEAT_PENALTY=1.2

# --- 翻訳異常検出 ---
OUTPUT_REPEAT_THRESHOLD=3
INPUT_REPEAT_THRESHOLD=4
INPUT_UNIQUE_RATIO_THRESHOLD=0.3

# ============================================================
# TTS（音声合成）— OmniVoice
# ============================================================

OMNIVOICE_MODEL=k2-fsa/OmniVoice
OMNIVOICE_DTYPE=float32
OMNIVOICE_NUM_STEP=32
OMNIVOICE_GUIDANCE_SCALE=2.0
OMNIVOICE_SPEED=1.0
OMNIVOICE_DURATION_SCALE=1.15
OMNIVOICE_REFERENCE_MIN_SEC=3.0
OMNIVOICE_REFERENCE_MAX_SEC=15.0
OMNIVOICE_REFERENCE_TARGET_SEC=8.0
OMNIVOICE_DURATION_TOLERANCE=0.5
OMNIVOICE_QUALITY_RETRIES=2
